{
  "name": "@mwl/chatwoot-bridge",
  "version": "1.0.4",
  "type": "module",
  "description": "Framework-agnostic Chatwoot widget bridge shared across MWL Group sites.",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./browser": {
      "default": "./dist/browser/index.global.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
